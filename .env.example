# Copie este arquivo para .env e preencha com seus valores reais.
# O arquivo .env nunca deve ser commitado (já está no .gitignore).

# Chave da API Google Gemini (obtenha em https://aistudio.google.com/apikey)
GEMINI_API_KEY=sua_chave_aqui

# Opcional: nome alternativo aceito pelo projeto
# GOOGLE_API_KEY=sua_chave_aqui

# Opcional: modelo Gemini (padrão: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Chave secreta do Flask (gere uma string aleatória longa)
SECRET_KEY=altere_para_uma_chave_secreta_forte

# Banco PostgreSQL em produção (Render, Railway, etc.)
# Deixe vazio para usar SQLite local em instance/dados.db
# DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco
